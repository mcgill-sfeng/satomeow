{
  "name": "agent-dsl",
  "displayName": "Agent DSL",
  "description": "Syntax highlighting for .agent files",
  "version": "0.1.0",
  "main": "./extension.js",
  "activationEvents": ["onLanguage:agent"],
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "agent",
        "aliases": ["Agent DSL", "agent"],
        "extensions": [".agent"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "agent",
        "scopeName": "source.agent",
        "path": "./syntaxes/agent.tmLanguage.json"
      }
    ]
  }
}
