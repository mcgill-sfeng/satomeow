from __future__ import annotations

import argparse
import json
import os
import sys
from types import SimpleNamespace

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
LIB_DIR = os.path.join(BASE_DIR, "lib")
if LIB_DIR not in sys.path:
    sys.path.insert(0, LIB_DIR)

from agent.metamodel import ChatModeAgent, Executor, OutputField, OutputSpec, Planner, System, Task
from agent.runtime import AgentSystemRuntime

SOURCE_MODEL_PATH = os.path.join(BASE_DIR, "model.agent")


def _build_system() -> System:
    system = System()

    planner = Planner()
    planner.llm = {{ system.planner.llm|pyrepr }}
    planner.reasoningStrategy = {{ system.planner.reasoningStrategy|pyrepr }}
    planner.persona = {{ system.planner.persona|pyrepr }}
    planner.rules = [
{% for rule in system.planner.rules %}
        SimpleNamespace(name={{ rule.name|pyrepr }}, negative={{ rule.negative|pyrepr }}, description={{ rule.description|pyrepr }}),
{% endfor %}
    ]
    system.planner = planner

    system.rules = [
{% for rule in system.rules %}
        SimpleNamespace(name={{ rule.name|pyrepr }}, negative={{ rule.negative|pyrepr }}, description={{ rule.description|pyrepr }}),
{% endfor %}
    ]
    // TODO: this thing needs more refactoring to remove dependency on serialized structures
    system.skills = [
{% for skill in system.skills %}
        _build_skill(
            name={{ skill.name|pyrepr }},
            command={{ skill.command|pyrepr }},
            description={{ skill.description|pyrepr }},
            arguments=[
{% for arg in skill.skillArguments %}
                {"name": {{ arg.name|pyrepr }}, "description": {{ arg.description|pyrepr }}},
{% endfor %}
            ],
        ),
{% endfor %}
    ]
    system.executors = [
{% for executor in system.executors %}
        _build_executor(
            llm={{ executor.llm|pyrepr }},
            reasoning_strategy={{ executor.reasoningStrategy|pyrepr }},
            persona={{ executor.persona|pyrepr }},
            rules=[
{% for rule in executor.rules %}
                {"name": {{ rule.name|pyrepr }}, "negative": {{ rule.negative|pyrepr }}, "description": {{ rule.description|pyrepr }}},
{% endfor %}
            ],
            task_data={
                "name": {{ executor.task.name|pyrepr }},
                "input_description": {{ executor.task.inputDescription|pyrepr }},
                "behavior": {{ executor.task.behavior|pyrepr }},
                "output_spec": {
                    "format": {{ executor.task.outputSpec.format|pyrepr }},
                    "fields": [
{% for field in executor.task.outputSpec.fields %}
                        {"name": {{ field.name|pyrepr }}, "type": {{ field.type|pyrepr }}},
{% endfor %}
                    ],
                },
                "examples": [
{% for example in executor.task.examples %}
                    {
                        "input": {{ example.input|pyrepr }},
                        "commands": [
{% for command in example.commands %}
                            {
                                "tool_name": {{ command.toolName|pyrepr }},
                                "arguments": [
{% for arg in command.arguments %}
                                    {"name": {{ arg.name|pyrepr }}, "value": {{ arg.value|pyrepr }}},
{% endfor %}
                                ],
                            },
{% endfor %}
                        ],
                        "output": {{ example.output|pyrepr }},
                    },
{% endfor %}
                ],
                "skills": [
{% for skill in executor.task.skills %}
                    {
                        "name": {{ skill.name|pyrepr }},
                        "command": {{ skill.command|pyrepr }},
                        "description": {{ skill.description|pyrepr }},
                        "arguments": [
{% for arg in skill.skillArguments %}
                            {"name": {{ arg.name|pyrepr }}, "description": {{ arg.description|pyrepr }}},
{% endfor %}
                        ],
                    },
{% endfor %}
                ],
            },
        ),
{% endfor %}
    ]

{% if system.chatAgent is none %}
    system.chatAgent = None
{% else %}
    chat_agent = ChatModeAgent()
    chat_agent.name = {{ system.chatAgent.name|pyrepr }}
    chat_agent.persona = {{ system.chatAgent.persona|pyrepr }}
    chat_agent.llm = {{ system.chatAgent.llm|pyrepr }}
    chat_agent.reasoningStrategy = {{ system.chatAgent.reasoningStrategy|pyrepr }}
    chat_agent.goal = {{ system.chatAgent.goal|pyrepr }}
    chat_agent.questions = [
{% for question in system.chatAgent.questions %}
        {{ question|pyrepr }},
{% endfor %}
    ]
    chat_agent.executor_ref = {{ system.chatAgent.executor_ref|pyrepr }}
    system.chatAgent = chat_agent
{% endif %}

    return system


def _build_skill(*, name, command, description, arguments):
    return SimpleNamespace(
        name=name,
        command=command,
        description=description,
        skillArguments=[SimpleNamespace(**arg) for arg in arguments],
    )


def _build_executor(*, llm, reasoning_strategy, persona, rules, task_data):
    executor = Executor()
    executor.llm = llm
    executor.reasoningStrategy = reasoning_strategy
    executor.persona = persona
    executor.rules = [SimpleNamespace(**rule) for rule in rules]

    task = Task()
    task.name = task_data["name"]
    task.inputDescription = task_data["input_description"]
    task.behavior = task_data["behavior"]
    task.outputSpec = OutputSpec(
        format=task_data["output_spec"]["format"],
        fields=[OutputField(name=field["name"], type=field["type"]) for field in task_data["output_spec"]["fields"]],
    )
    task.examples = [
        SimpleNamespace(
            input=example["input"],
            output=example["output"],
            commands=[
                SimpleNamespace(
                    toolName=command["tool_name"],
                    arguments=[SimpleNamespace(name=arg["name"], value=arg["value"]) for arg in command["arguments"]],
                )
                for command in example["commands"]
            ],
        )
        for example in task_data["examples"]
    ]
    task.skills = [
        _build_skill(
            name=skill["name"],
            command=skill["command"],
            description=skill["description"],
            arguments=skill["arguments"],
        )
        for skill in task_data["skills"]
    ]
    executor.task = task
    return executor


def build_runtime(tool_executor=None, use_dspy=False):
    return AgentSystemRuntime(
        _build_system(),
        tool_executor=tool_executor,
        source_model_path=SOURCE_MODEL_PATH,
        use_dspy=use_dspy,
    )


def run_agent(user_input: str, *, tool_executor=None, use_dspy=False):
    runtime = build_runtime(
        tool_executor=tool_executor,
        use_dspy=use_dspy,
    )
    return runtime.run(user_input)


def main(argv=None):
    parser = argparse.ArgumentParser(
        description="Run the portable agent bundle."
    )
    parser.add_argument("prompt", help="User input to send to the generated agent")
    parser.add_argument(
        "--json",
        action="store_true",
        help="Print the full run result as JSON",
    )
    parser.add_argument(
        "--dspy",
        action="store_true",
        help="Use the compile-time DSPy-style example prompt enrichment path",
    )

    args = parser.parse_args(argv)
    result = run_agent(args.prompt, use_dspy=args.dspy)

    if args.json:
        print(json.dumps({
            "executor_name": result.executor_name,
            "planner_reason": result.planner_reason,
            "output": result.output,
            "output_format": result.output_format,
            "raw_response": result.raw_response,
            "system_prompt": result.system_prompt,
            "user_input": result.user_input,
            "raw_responses": list(result.raw_responses),
            "tool_results": [
                {
                    "command": tool.command,
                    "stdout": tool.stdout,
                    "stderr": tool.stderr,
                    "exit_code": tool.exit_code,
                }
                for tool in result.tool_results
            ],
        }, indent=2))
        return

    if isinstance(result.output, dict):
        print(json.dumps(result.output, indent=2))
        return

    print(result.output)


if __name__ == "__main__":
    main()
