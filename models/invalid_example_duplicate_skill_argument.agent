llm: "gpt-5.4-nano"
reasoning: "chain-of-thought"

Summarize : "text summarizer" {
    input: "A long document"
    behavior: "Summarize the document"
    skills: [web_search]
    example {
        input: "doc text"
        commands: ["read"]
        output: "summary"
    }
}

web_search {
    command: "search_web"
    description: "Search the web"
    param query: "The search query"
    param query: "Duplicate argument name"
}
