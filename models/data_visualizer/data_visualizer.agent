llm: "gpt-5.4-nano"

DataVisualizer : "data visualization agent" {
    input: "A request to visualize a dataset from models/data_visualizer/data"
    behavior: "Ensure a local Python environment exists, run the visualization script on aligned data, write and run a preprocessing script when conversion is straightforward, and otherwise return a structured explanation."
    output: json {
        status: str,
        message: str,
        artifact_path: str,
        preprocessed_data_path: str,
        preprocessor_script_path: str
    }
    skills: [preparePythonEnv, runPythonScript, writePreprocessor]
    rules: [preserveInputData, reportFailuresClearly]

    example {
        input: "Visualize the aligned monthly sales data in models/data_visualizer/data/aligned_sales.json"
        commands: [
            preparePythonEnv(demo_root: "models/data_visualizer"),
            runPythonScript(
                python_bin: "models/data_visualizer/.venv/bin/python",
                script_path: "models/data_visualizer/scripts/visualize_data.py",
                input_path: "models/data_visualizer/data/aligned_sales.json",
                output_path: "models/data_visualizer/output/aligned_chart.svg"
            )
        ]
        output: "{\"status\":\"success\",\"message\":\"Visualization created directly from aligned input.\",\"artifact_path\":\"models/data_visualizer/output/aligned_chart.svg\",\"preprocessed_data_path\":\"\",\"preprocessor_script_path\":\"\"}"
    }

    example {
        input: "Visualize the monthly revenue CSV in models/data_visualizer/data/monthly_revenue.csv"
        commands: [
            preparePythonEnv(demo_root: "models/data_visualizer"),
            writePreprocessor(
                python_bin: "models/data_visualizer/.venv/bin/python",
                writer_script_path: "models/data_visualizer/scripts/write_preprocessor.py",
                template_name: "monthly_csv_to_json",
                output_script_path: "models/data_visualizer/generated/monthly_csv_to_json.py"
            ),
            runPythonScript(
                python_bin: "models/data_visualizer/.venv/bin/python",
                script_path: "models/data_visualizer/generated/monthly_csv_to_json.py",
                input_path: "models/data_visualizer/data/monthly_revenue.csv",
                output_path: "models/data_visualizer/generated/monthly_revenue_converted.json"
            ),
            runPythonScript(
                python_bin: "models/data_visualizer/.venv/bin/python",
                script_path: "models/data_visualizer/scripts/visualize_data.py",
                input_path: "models/data_visualizer/generated/monthly_revenue_converted.json",
                output_path: "models/data_visualizer/output/converted_chart.svg"
            )
        ]
        output: "{\"status\":\"success\",\"message\":\"The CSV data was converted with a newly written preprocessing script before visualization.\",\"artifact_path\":\"models/data_visualizer/output/converted_chart.svg\",\"preprocessed_data_path\":\"models/data_visualizer/generated/monthly_revenue_converted.json\",\"preprocessor_script_path\":\"models/data_visualizer/generated/monthly_csv_to_json.py\"}"
    }

    example {
        input: "Visualize the unsupported dataset in models/data_visualizer/data/unsupported_nested.json"
        commands: []
        output: "{\"status\":\"unsupported_input\",\"message\":\"The dataset cannot be converted into the required list[{label, value}] structure without inventing numeric values.\",\"artifact_path\":\"\",\"preprocessed_data_path\":\"\",\"preprocessor_script_path\":\"\"}"
    }
}

do preserveInputData: "leave the original input files unchanged"
do reportFailuresClearly: "return a structured explanation when visualization cannot proceed safely"

preparePythonEnv {
    command: "if [ ! -d <demo_root>/.venv ]; then python3 -m venv <demo_root>/.venv || python3 -m venv --without-pip <demo_root>/.venv; fi; if [ -x <demo_root>/.venv/bin/pip ] && grep -q '[^[:space:]#]' <demo_root>/requirements.txt; then <demo_root>/.venv/bin/pip install -r <demo_root>/requirements.txt; fi"
    description: "Create or activate the demo Python environment using the provided requirements.txt"
    param demo_root: "Path to the demo root directory"
}

runPythonScript {
    command: "<python_bin> <script_path> --input <input_path> --output <output_path>"
    description: "Run an existing Python script with input and output paths"
    param python_bin: "The Python interpreter inside the prepared environment"
    param script_path: "Path to the Python script to execute"
    param input_path: "Input dataset path"
    param output_path: "Output artifact path"
}

writePreprocessor {
    command: "<python_bin> <writer_script_path> --template <template_name> --output <output_script_path>"
    description: "Write a new preprocessing script from a template before running it"
    param python_bin: "The Python interpreter inside the prepared environment"
    param writer_script_path: "The helper that writes a new preprocessing script"
    param template_name: "The conversion template to materialize"
    param output_script_path: "Where to write the generated preprocessing script"
}
