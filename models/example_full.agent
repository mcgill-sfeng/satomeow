System {
    Planner {
        reasoningStrategy: "deliberative"
        llm: "gpt-5"
        persona: "senior planning agent"
        rules: safety_rule, format_rule
    }

    Executor {
        reasoningStrategy: "react"
        llm: "gpt-5"
        persona: "execution agent"
        rules: safety_rule
        task Task {
            name: "WebResearch"
            inputDescription: "A user question that requires web research"
            behavior: "Search, extract, and summarize relevant information"
            outputSchema: "markdown"
            examples {
                TaskExample {
                    input: "Find recent news about AI regulation"
                    commands: ["search_web", "open_results", "summarize"]
                    output: "A concise summary of recent AI regulation news"
                }
                TaskExample {
                    input: "Compare two APIs"
                    commands: ["read_docs", "extract_features", "compare"]
                    output: "A comparison report"
                }
            }
            skills: web_search, doc_reader
        }
    }

    Rule safety_rule {
        negative: false
        description: "Do not hallucinate facts"
    }

    Rule format_rule {
        negative: false
        description: "Always produce structured output"
    }

    Skill web_search {
        command: "search_web"
        description: "Search the web"
        skillArguments {
            SkillArgument {
                name: "query"
                description: "The search query"
            }
        }
    }

    Skill doc_reader {
        command: "read_docs"
        description: "Read documentation pages"
        skillArguments {
            SkillArgument {
                name: "url"
                description: "The document URL"
            }
            SkillArgument {
                name: "section"
                description: "Optional section name"
            }
        }
    }
}


