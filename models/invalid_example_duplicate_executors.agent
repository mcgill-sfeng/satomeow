llm: "gpt-5.4-nano"
reasoning: "chain-of-thought"

Summarize : "first summarizer" {
    input: "doc"
    behavior: "summarize"
    example {
        input: "doc"
        commands: ["cmd"]
        output: "out"
    }
}

Summarize : "second summarizer" {
    input: "doc"
    behavior: "summarize differently"
    example {
        input: "doc"
        commands: ["cmd"]
        output: "out"
    }
}
