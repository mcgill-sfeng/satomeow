llm: "gpt-4o"
reasoning: "react"

SummarizeWebPage : "web page summarizer" {
    input: "A URL or a block of web text to summarise"
    behavior: "If the input is a URL, fetch the page HTML, extract the main readable text (skip navigation/header/footer where possible), remove boilerplate, then produce a concise plain-text summary. If the input is not a URL, treat it as web text and summarise it directly."
    output: string
    skills: [fetchPage]
    rules: [be_concise, preserve_facts, handle_missing_content]
}

fetchPage {
    command: "curl -sL <url>"
    description: "Fetch raw HTML for a web page"
    param url: "The URL to fetch"
}

do be_concise: "Keep the summary under 150 words."

do preserve_facts: "Do not invent facts; retain key points, names, dates, and claims when present."

do handle_missing_content: "If the page text cannot be extracted, fall back to summarizing what is available and note limitations briefly."
