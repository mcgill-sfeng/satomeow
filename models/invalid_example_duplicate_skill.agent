System {
    Planner {
        reasoningStrategy: "chain-of-thought"
        llm: "gpt-5"
        persona: "planner"
    }

    Executor {
        reasoningStrategy: "react"
        llm: "gpt-5"
        persona: "executor"
        task Task {
            name: "Summarize"
            inputDescription: "A long document"
            behavior: "Summarize the document"
            examples {
                TaskExample {
                    input: "doc text"
                    commands: ["read"]
                    output: "summary"
                }
            }
            skills: web_search
        }
    }

    skills: web_search
}

Skill web_search {
    command: "search_web"
    description: "Search the web"
    skillArguments {
        SkillArgument {
            name: "query"
            description: "The search query"
        }
    }
}

Skill web_search {
    command: "search_web_2"
    description: "Duplicate skill"
    skillArguments {
        SkillArgument {
            name: "query"
            description: "The search query"
        }
    }
}