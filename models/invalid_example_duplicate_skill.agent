llm: "gpt-5.4-nano"

Summarize : "text summarizer" {
    input: "A long document"
    behavior: "Summarize the document"
    skills: [web_search]
    example {
        input: "doc text"
        commands: [web_search(query: "doc text")]
        output: "summary"
    }
}

web_search {
    command: "search_web"
    description: "Search the web"
    param query: "The search query"
}

web_search {
    command: "search_web_2"
    description: "Duplicate skill"
    param query: "The search query"
}
